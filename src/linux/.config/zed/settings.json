// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "sort_by_path": true,
  },
  "base_keymap": "VSCode",
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
    },
  },
  "title_bar": {
    "show_sign_in": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b",
      "enable_thinking": false,
    },
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "ollama",
    "ollama": {
      "api_url": "http://localhost:11434",
      "model": "deepseek-coder:6.7b-base",
    },
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Soft Charmed Icons",
  },
  "ui_font_size": 18.0,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "dark",
    "light": "Dayfox - blurred",
    "dark": "Carbonfox - blurred",
  },
  "theme_overrides": {
    "Carbonfox - blurred": {
      "border": "#ffffff30",
      "editor.active_line.background": "#ffffff10",
      // Give the current tab a focus color to make it clear which is focused
      "tab.active_background": "#ffffff20",
      // Make it a bit darker to improve readability
      "background": "#00000080",
      "surface.background": "#000000BF",
      "status_bar.background": "#00000080",
      "title_bar.background": "#00000080",
      "title_bar.inactive_background": "#00000080",
    },
  },
  "linux": {
    "theme_overrides": {
      "Carbonfox - blurred": {
        "background.appearance": "transparent",
      },
    },
  },
  "toolbar": {
    "agent_review": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
