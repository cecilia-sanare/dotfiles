{
  "include": [
    "~/.config/waybar/components/widgets/bluetooth.jsonc",
    "~/.config/waybar/components/widgets/clock.jsonc",
    "~/.config/waybar/components/widgets/cpu.jsonc",
    "~/.config/waybar/components/widgets/disk.jsonc",
    "~/.config/waybar/components/widgets/lock.jsonc",
    "~/.config/waybar/components/widgets/network.jsonc",
    "~/.config/waybar/components/widgets/notify.jsonc",
    "~/.config/waybar/components/widgets/pulseaudio.jsonc",
    "~/.config/waybar/components/widgets/tray.jsonc",
  ],

  "layer": "bottom",
  "position": "top",
  "margin-bottom": -25,
  "spacing": 0,
  "reload_style_on_change": true,

  "ext/workspaces": {
    "format": "{name}: {icon}",
    "on-click": "activate",
    "format-icons": {
      "active": "",
      "default": "",
    },
    "ignore-hidden": true,
    "sort-by-id": true,
  },

  "modules-left": ["group/glock", "group/gcpu", "group/gdisk", "ext/workspaces"],
  "modules-center": ["group/gclock", "group/gnotify"],
  "modules-right": ["group/gtray", "group/gbluetooth", "group/gnetwork", "group/gpulseaudio"],
}
